# ============================================================
#  .env.example — Monitor de Câmbio
#  Copie para .env e preencha com suas credenciais reais.
#  NUNCA faça commit do arquivo .env no Git!
# ============================================================

# ── API de câmbio (https://www.exchangerate-api.com) ────────
# Plano gratuito: 1.500 requisições/mês
EXCHANGE_API_KEY=sua_chave_aqui

# ── API de notícias (https://newsapi.org) ───────────────────
# Plano gratuito: 100 requisições/dia
NEWS_API_KEY=sua_chave_aqui

# ── Telegram Bot ────────────────────────────────────────────
# Crie um bot em @BotFather e pegue o token
TELEGRAM_TOKEN=123456:ABCDEF...
# ID do chat/grupo que receberá os alertas
TELEGRAM_CHAT_ID=987654321

# ── WhatsApp (CallMeBot) ────────────────────────────────────
20: # 1. Envie 'I allow callmebot to send me messages' para +34 644 66 32 18
21: # 2. Cole sua ApiKey e Número aqui
22: WHATSAPP_API_KEY=sua_apikey_aqui
23: WHATSAPP_PHONE=seu_numero_aqui
24: 
25: # ── E-mail SMTP (opcional — Gmail recomendado) ───────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
# Para Gmail use "Senha de app" em: myaccount.google.com/security
SMTP_PASSWORD=senha_de_app_16_digitos

# ── E-mails dos usuários ─────────────────────────────────────
ADMIN_EMAIL=admin@suaempresa.com
DEMO_EMAIL=demo@suaempresa.com
